# direnv config — `direnv allow` once after editing .env.local
#
# Put your secrets in .env.local (gitignored). Example:
#   export TF_VAR_hcloud_token=hetzner_api_token_here
#   export TF_VAR_ssh_key_name=my-key-name-in-hetzner-console
#
# Optional overrides:
#   export TF_VAR_server_type=cx22
#   export TF_VAR_server_location=hel1

dotenv_if_exists .env.local

# Bring opentofu + nixos-anywhere into PATH from nixpkgs.
use flake nixpkgs#opentofu nixpkgs#nixos-anywhere 2>/dev/null || \
  echo "tip: install direnv's nix integration, or run: nix shell nixpkgs#opentofu nixpkgs#nixos-anywhere"

# Fail loudly if the required vars are missing.
: "${TF_VAR_hcloud_token:?set TF_VAR_hcloud_token in .env.local}"
: "${TF_VAR_ssh_key_name:?set TF_VAR_ssh_key_name in .env.local}"
